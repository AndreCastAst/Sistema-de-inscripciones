# Servidor
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Base de datos PostgreSQL
# Nota: caracteres especiales en la contraseña deben estar URL-encoded (? = %3F)
DATABASE_URL="postgresql://usuario:contrasena@localhost:5432/sistema_inscripciones_colegio_ingenieros"

# Cloudinary (https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# Email Gmail SMTP
# Requiere App Password de Google (no la contraseña normal)
EMAIL_USER=tu_correo@gmail.com
EMAIL_PASSWORD=tu_app_password_de_16_caracteres

# RENIEC — apis.net.pe (https://apis.net.pe)
RENIEC_API_URL=https://api.apis.net.pe/v2/reniec/dni
RENIEC_API_TOKEN=tu_token_apis_net_pe

# MercadoPago (https://www.mercadopago.com.pe/developers)
MERCADO_PAGO_ACCESS_TOKEN=TEST-tu_access_token
MERCADO_PAGO_PUBLIC_KEY=TEST-tu_public_key

# URLs base (usar dominio público en producción para webhooks)
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000
